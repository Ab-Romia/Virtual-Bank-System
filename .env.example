# Copy to .env and adjust. .env is gitignored and must never be committed.

# ---- Postgres -------------------------------------------------------------
POSTGRES_USER=vbank
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Kafka ----------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ---- JWT (RS256) ----------------------------------------------------------
# In production, supply a PEM keypair here. In development, user-service
# generates an ephemeral keypair on startup if these are left blank.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ---- AI assistant (OpenRouter, free model) --------------------------------
# The assistant uses OpenRouter (OpenAI-compatible). Leave the key blank to run
# without AI; the assistant then returns a clear "not configured" message.
# AI_MODEL can be any OpenRouter model id; a free, tool-capable model is the
# default. Embeddings run locally, so they need no key.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=meta-llama/llama-3.3-70b-instruct:free
