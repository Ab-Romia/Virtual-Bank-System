### Virtual Bank System: API walkthrough.
### Start the stack first: docker compose up --build
### Then run these top to bottom (VS Code REST Client or the IntelliJ HTTP client).

@gateway = http://localhost:8080

### Register a user
POST {{gateway}}/api/auth/register
Content-Type: application/json

{ "username": "alice", "email": "alice@example.com", "password": "pw123456", "fullName": "Alice" }

### Log in (captures the access token for the calls below)
# @name login
POST {{gateway}}/api/auth/login
Content-Type: application/json

{ "username": "alice", "password": "pw123456" }

@token = {{login.response.body.accessToken}}

### Open a checking account
# @name checking
POST {{gateway}}/api/accounts
Authorization: Bearer {{token}}
Content-Type: application/json

{ "type": "CHECKING", "currency": "USD" }

@from = {{checking.response.body.id}}

### Open a savings account
# @name savings
POST {{gateway}}/api/accounts
Authorization: Bearer {{token}}
Content-Type: application/json

{ "type": "SAVINGS", "currency": "USD" }

@to = {{savings.response.body.id}}

### Deposit into checking
POST {{gateway}}/api/accounts/{{from}}/deposit
Authorization: Bearer {{token}}
Content-Type: application/json

{ "amount": 100 }

### Start a transfer
# @name transfer
POST {{gateway}}/api/transfers
Authorization: Bearer {{token}}
Content-Type: application/json
Idempotency-Key: demo-1

{ "fromAccountId": "{{from}}", "toAccountId": "{{to}}", "amount": 30, "currency": "USD" }

@transferId = {{transfer.response.body.transferId}}

### Read the transfer status (poll until COMPLETED)
GET {{gateway}}/api/transfers/{{transferId}}
Authorization: Bearer {{token}}

### Read the audit history for the transfer
GET {{gateway}}/api/audit/transfers/{{transferId}}
Authorization: Bearer {{token}}

### List my accounts
GET {{gateway}}/api/accounts
Authorization: Bearer {{token}}

### Ask the assistant (needs the ai profile and an OPENROUTER_API_KEY)
POST {{gateway}}/api/assistant/chat
Authorization: Bearer {{token}}
Content-Type: application/json

{ "message": "What is my balance?" }
